// Final Prisma schema after architecture approval

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// Enums
enum UserRole {
  DRIVER
  SUPPORT
  ADMIN
  SUPERADMIN
}

enum LeadStatus {
  NEW
  CONTACTED
  FOLLOW_UP
  QUALIFIED
  CONVERTED
  LOST
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum CallbackStatus {
  NEW
  IN_PROGRESS
  COMPLETED
  CLOSED
}

enum EmailStatus {
  PENDING
  SENT
  FAILED
}

enum EmailType {
  WELCOME
  APPOINTMENT_CONFIRMATION
  APPOINTMENT_REMINDER
  RENEWAL_REMINDER
  BILLING_RECEIPT
  PASSWORD_RESET
}

enum SubscriptionStatus {
  ACTIVE
  TRIAL
  EXPIRED
  CANCELLED
  PAST_DUE
  SUSPENDED
}

// Core models (unchanged except optional tenantId for future migration)
model User {
  id                String            @id @default(uuid())
  email             String            @unique
  name              String
  password          String
  phone             String?
  role              UserRole          @default(DRIVER)
  isVerified        Boolean           @default(false)
  isActive          Boolean           @default(true)
  preferredLanguage String            @default("English")
  country           String            @default("US")
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  // Relations
  vehicles          Vehicle[]
  complianceChecks  ComplianceCheck[]
  auditLogs         AuditLog[]
  driverProfile     DriverProfile?
  sessions          UserSession[]
  notifications     Notification[]
  // Placeholder relations removed for now

  @@index([email])
}

model DriverProfile {
  id                 String   @id @default(uuid())
  userId             String   @unique
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  driverType         String   // "TLC", "Uber", "Lyft", "Commercial", "Other"
  languages          String[] // ["English", "Spanish", etc.]
  documentsUploaded  Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model UserSession {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  device    String?  // User agent info
  ip        String?
  isValid   Boolean  @default(true)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([token])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String   // "REGISTER", "LOGIN", "PASSWORD_RESET_REQ", etc.
  ip        String?
  userAgent String?
  timestamp DateTime @default(now())

  @@index([userId])
}

model Vehicle {
  id        String   @id @default(uuid())
  make      String
  model     String
  year      Int
  plate     String   @unique
  vin       String   @unique
  driverId  String
  driver    User     @relation(fields: [driverId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ComplianceCheck {
  id          String   @id @default(uuid())
  title       String
  description String?
  dueDate     DateTime
  status      String   // "PENDING", "COMPLETED", "EXPIRED"
  driverId    String
  driver      User     @relation(fields: [driverId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ... (Other existing models such as EarningRecord, ExpenseRecord, ChatHistory, Document, etc.) ...

model Notification {
  id                String   @id @default(uuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id])
  title             String
  message           String
  body              String   // compatibility field
  type              String   // INFO | WARNING | SUCCESS | ERROR
  channel           String   // EMAIL | SMS | WHATSAPP | VOICE | IN_APP
  status            String   // PENDING | SENT | FAILED | DELIVERED
  sentAt            DateTime?
  deliveredAt       DateTime?
  readAt            DateTime?
  failureReason     String?
  providerMessageId String?
  createdAt         DateTime @default(now())

  @@index([userId])
}

// The rest of the original schema (Ticket, Invoice, Payment, etc.) remains unchanged.

// Placeholder models for currently undefined types (to be expanded later)
model EarningRecord {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
}

model ExpenseRecord {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
}

model ChatHistory {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
}

model DocActivityLog {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
}

model Document {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
}

model Subscription {
  id        String   @id @default(uuid())
  status    String?
  createdAt DateTime @default(now())
}

model Lead {
  id        String   @id @default(uuid())
  name      String?
  createdAt DateTime @default(now())
}

model Ticket {
  id                  String   @id @default(uuid())
  ticketId            String   @unique
  driverId            String
  title               String
  description         String
  category            String
  status              String
  priority            String
  handlingMode        String   @default("AI_MANAGED") // "AI_MANAGED" or "HUMAN_MANAGED"
  humanTakenOverById  String?
  humanTakenOverAt    DateTime?
  lastModeChangedAt   DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  VoiceCall           VoiceCall[]
}

model TicketAuditLog {
  id            String   @id @default(uuid())
  ticketId      String
  action        String
  oldMode       String?
  newMode       String?
  changedById   String?
  changedByRole String?
  createdAt     DateTime @default(now())
}

model TicketMessage {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
}

model StatusHistory {
  id        String   @id @default(uuid())
  ticketId  String?
  status    String?
  createdAt DateTime @default(now())
}

model InternalNote {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
}

model Escalation {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
}

model AIChat {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
}

model AIUsage {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
}

model AdminLog {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
}

model UserPreferences {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
}

model Appointment {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
}

model ShiftLog {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
}

model DriverActivity {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
}

model ExportRecord {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
}

model VoiceCall {
  id          String            @id @default(uuid())
  sid         String            @unique
  caller      String
  status      String            // ACTIVE, COMPLETED, FAILED, TRANSFERRED
  durationSec Int?
  language    String            @default("English")
  intent      String?
  outcome     String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  ticketId    String?
  ticket      Ticket?           @relation(fields: [ticketId], references: [id])
  transcripts VoiceTranscript[]
}

model VoiceTranscript {
  id        String    @id @default(uuid())
  callId    String
  call      VoiceCall @relation(fields: [callId], references: [id], onDelete: Cascade)
  speaker   String    // DRIVER, AI, AGENT
  text      String
  timestamp DateTime  @default(now())
}

model VoiceSession {
  id            String   @id @default(uuid())
  sid           String   @unique
  metadata      String?
  detectedLang  String?
  collectedData String?  @default("{}")
  currentNode   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

