      "id": 1,
      "title": "JNI Backend CPU Utilization",
      "type": "timeseries",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prom-datasource"
          },
          "editorMode": "code",
          "expr": "sum(rate(container_cpu_usage_seconds_total{container=\"jini-backend\"}[5m])) by (pod) * 100",
          "legendFormat": "{{pod}}",
          "range": true,
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "id": 2,
      "title": "JNI Backend Memory Footprint",
      "type": "timeseries",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prom-datasource"
          },
          "editorMode": "code",
          "expr": "sum(container_memory_working_set_bytes{container=\"jini-backend\"}) by (pod) / (1024 * 1024)",
          "legendFormat": "{{pod}} (MB)",
          "range": true,
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "id": 3,
      "title": "API Request Rate & Latency Response Speed",
      "type": "timeseries",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prom-datasource"
          },
          "editorMode": "code",
          "expr": "sum(rate(http_requests_total[5m])) by (status)",
          "legendFormat": "Status {{status}}",
          "range": true,
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "id": 4,
      "title": "BullMQ Active Workers Pending Jobs Delay",
      "type": "timeseries",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prom-datasource"
          },
          "editorMode": "code",
          "expr": "bullmq_queue_waiting_jobs_count",
          "legendFormat": "{{queue}} Pending Jobs",
          "range": true,
          "refId": "A"
